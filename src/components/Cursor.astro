<!-- Chain-handle ring cursor — only visible when hovering the pull chain handle -->
<div class="cursor-ring" id="cursor-ring">
  <span class="cursor-label">Pull</span>
</div>

<script>
  // Lightweight manual cursor ring — replaces custom-cursor.js
  const ring = document.getElementById('cursor-ring');
  let ringX = -100, ringY = -100;
  let targetX = -100, targetY = -100;
  let visible = false;
  let raf = null;

  function lerp(a, b, t) { return a + (b - a) * t; }

  function animate() {
    ringX = lerp(ringX, targetX, 0.15);
    ringY = lerp(ringY, targetY, 0.15);
    ring.style.transform = `translate(${ringX}px, ${ringY}px)`;
    if (visible) raf = requestAnimationFrame(animate);
  }

  document.addEventListener('mousemove', e => {
    targetX = e.clientX;
    targetY = e.clientY;
    // When invisible, snap position so ring doesn't fly in from afar
    if (!visible) {
      ringX = targetX;
      ringY = targetY;
      ring.style.transform = `translate(${ringX}px, ${ringY}px)`;
    } else if (!raf) {
      raf = requestAnimationFrame(animate);
    }
  });

  // Expose show/hide for Hero.astro chain events
  window.__cursorRing = {
    show() {
      visible = true;
      ring.classList.add('cursor-ring--visible');
      if (!raf) raf = requestAnimationFrame(animate);
    },
    hide() {
      visible = false;
      ring.classList.remove('cursor-ring--visible');
      raf = null;
    },
    showLabel() { ring.classList.add('cursor-ring--pull-label'); },
    hideLabel() { ring.classList.remove('cursor-ring--pull-label'); },
    setLabel(text) { const el = ring.querySelector('.cursor-label'); if (el) el.textContent = text; },
    hideAll() {
      ring.classList.add('cursor-ring--hidden');
      ring.classList.remove('cursor-ring--pull-label');
    },
    unhideAll() {
      ring.classList.remove('cursor-ring--hidden');
    }
  };
</script>

