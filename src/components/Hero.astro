<div class="relative min-h-[100dvh] flex flex-col px-2 md:px-10">

  <!-- Hero content — centered -->
  <div class="pt-[calc(50dvh-9rem)] md:pt-[calc(50dvh-15rem)] pb-8 md:pb-12 flex flex-col items-center">

    <!-- Name + body copy — width driven by h1 via JS after font load -->
    <div id="hero-block" class="text-center md:text-left min-w-0">
      <h1 id="hero-name" class="font-display text-[#3639a0] dark:text-[#9bbc0f] leading-none uppercase inline-flex flex-col relative">
        <span class="block hero-matt intro-fade" style="opacity:0"><span class="kern-M">M</span><span class="kern-A1">A</span><span class="kern-T1">T</span><span class="kern-T2">T</span></span>
        <!-- Face overlapping between MATT and STENBACK -->
        <div class="face-container">
          <div class="face-wrap cursor-default relative">
            <div class="absolute bottom-0 inset-x-[-5%] h-[1.5px] z-10 shelf-line intro-shelf" style="opacity:0"></div>
            <img
              src="/images/me.png"
              alt="Matt Stenback"
              class="peek-img intro-face w-full h-full object-cover object-top mix-blend-multiply dark:mix-blend-normal"
              style="transform:translateY(100%)"
            />
          </div>
        </div>
        <div class="pixel-corners speech-balloon" id="speech-balloon">Hello there!</div>
        <span class="block hero-stenback intro-fade" style="opacity:0;--intro-delay:120ms"><span class="kern-S">S</span><span class="kern-T3">T</span><span class="kern-E">E</span><span class="kern-N">N</span><span class="kern-B">B</span><span class="kern-A2">A</span><span class="kern-C">C</span><span class="kern-K">K</span></span>
      </h1>
      <div id="hero-body" class="mt-14 md:mt-16 text-left intro-fade" style="opacity:0;--intro-delay:240ms">
        <div>
          <p class="font-body text-[18px] md:text-[22px] text-indigo dark:text-paper leading-[1.4] mb-3">
            I'm a designer and developer with a particular interest in UX and the
            practical application of AI. I get up in the morning for a big vision,
            and I stay up late for the small details.
          </p>
          <p class="font-body text-[18px] md:text-[22px] text-indigo dark:text-paper leading-[1.4]">
            Currently at <a href="https://spellbook.legal" target="_blank">Spellbook</a>
          </p>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Pull-chain dark mode toggle — fixed top-right -->
<div id="chain-root" class="fixed left-1/2 -translate-x-1/2 z-50 flex flex-col items-center"
  style="top: -10px; width: 20px; user-select: none; -webkit-user-select: none; visibility: hidden;">

  <!-- Chain links (SVG — built by JS) -->
  <svg id="chain-svg" width="20" xmlns="http://www.w3.org/2000/svg"
    style="overflow: visible; display: block; flex-shrink: 0;"
    shape-rendering="crispEdges">
  </svg>
  <!-- Invisible hit-area for handle cursor -->
  <div id="handle-hit" style="position:absolute; width:24px; height:24px; border-radius:50%; pointer-events:auto; cursor: url('/images/cursor-grab.svg') 14 14, grab; transform: translate(-50%, -50%); touch-action: none;"></div>


</div>

<script>
  // ── Scripted NPC greeting sequence ──────────────────────────────
  function shuffle(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  const hellos = ['Hello there!', 'Well met!', 'Greetings, stranger'];
  const fixed = [
    '...', '...',
    '...our princess is in another castle',
    'The cake is a lie',
    'Stay awhile and listen',
    'Hey! Listen',
    'A wild MATT appeared',
    '...', '...............', '.............................................',
    'Are you still there?',
    "Oh, it's you",
    'Please stop poking me',
    'I can see you hovering',
    "We've been over this",
    "I'm starting to worry about you",
    "This wasn't in my contract",
    '!!!',
    'I only have so many lines',
    "You've seen them all now",
    "There's no secret ending",
    '...or is there?',
    'No. Really. There isn\'t. You can stop.',
    'You could just read the source code',
    "I'm not hiding anything, I promise",
    'Alright... If you insist...',
    '..............................',
    'Fine. You win.',
    'I hope you\'re happy',
    '...',
    '*slow clap*',
    '[Matt.exe has stopped responding]',
  ];

  let sequence = [...shuffle([...hellos]), ...fixed];
  let seqIndex = 0;
  const balloon = document.getElementById('speech-balloon');
  const faceWrap = document.querySelector('.face-container .face-wrap');
  let typeTimer = null;
  if (faceWrap && balloon) {
    faceWrap.addEventListener('mouseenter', () => {
      if (typeTimer) clearInterval(typeTimer);
      const text = sequence[Math.min(seqIndex, sequence.length - 1)];
      if (seqIndex < sequence.length) seqIndex++;
      if (seqIndex >= sequence.length) {
        const img = faceWrap.querySelector('.peek-img');
        if (img) img.classList.add('defeated');
      }
      balloon.style.width = '';
      balloon.textContent = text;
      const fullWidth = balloon.offsetWidth;
      balloon.style.width = fullWidth + 'px';
      balloon.textContent = '';
      let i = 0;
      typeTimer = setInterval(() => {
        balloon.textContent = text.slice(0, ++i);
        if (i >= text.length) {
          clearInterval(typeTimer);
          balloon.style.width = '';
        }
      }, 20);
    });
  }

  // ── Defeated state: click to peek ──────────────────────────────
  let peekTimeout = null;
  if (faceWrap && balloon) {
    faceWrap.addEventListener('click', () => {
      const img = faceWrap.querySelector('.defeated');
      if (!img) return;
      if (peekTimeout) clearTimeout(peekTimeout);
      if (typeTimer) clearInterval(typeTimer);
      img.classList.add('peeking');
      balloon.textContent = '!';
      peekTimeout = setTimeout(() => {
        img.classList.remove('peeking');
        balloon.textContent = '...';
      }, 1200);
    });
  }

  // ── Intro animation — wait for fonts + layout, then trigger ──
  // (actual animation start is deferred to the matchBlockWidth callback
  //  in the chain script to avoid racing the width measurement)
</script>

<script>
  // ── Constants ──────────────────────────────────────────────────
  const NUM_NODES = 14;
  const LINK_LEN  = 8;
  const NATURAL_H = (NUM_NODES - 1) * LINK_LEN; // 104px
  const MAX_BEADS = 35;
  const CX        = 10;
  const GRAVITY   = 0.5;
  const DAMPING   = 0.87;
  const ITERS     = 8;
  const TRIGGER   = 50;
  const MAX_PULL  = NATURAL_H * 2;
  const CURSOR_R  = 50;
  const CURSOR_F  = 0.15;
  const NS        = 'http://www.w3.org/2000/svg';

  const svg      = document.getElementById('chain-svg');
  const handleHit = document.getElementById('handle-hit');

  let nodes        = [];
  let linkEls      = [];
  let handleEl     = null;
  let dragging     = false;
  let handleHovered = false;
  let dragTargetX  = CX;
  let dragTargetY  = NATURAL_H;
  let startDragX   = CX;
  let startDragY   = NATURAL_H;
  let startClientX = 0;
  let startClientY = 0;
  let pendingToggle = false;
  let animId       = null;
  let mouseX       = -9999;
  let mouseY       = -9999;
  let prevMouseX   = -9999;
  let prevMouseY   = -9999;

  // ── Build SVG (defs + link elements) — pixel art style ──────
  (function buildSVG() {
    const defs = document.createElementNS(NS, 'defs');

    // Pixel bead: 6x6 square with 2px highlight
    const sym = document.createElementNS(NS, 'symbol');
    sym.id = 'bead-sym';
    sym.setAttribute('overflow', 'visible');
    const beadBase = document.createElementNS(NS, 'rect');
    beadBase.setAttribute('x', '-3'); beadBase.setAttribute('y', '-3');
    beadBase.setAttribute('width', '6'); beadBase.setAttribute('height', '6');
    beadBase.setAttribute('fill', '#a0a0a0');
    sym.appendChild(beadBase);
    // Highlight pixel (top-left)
    const beadHi = document.createElementNS(NS, 'rect');
    beadHi.setAttribute('x', '-3'); beadHi.setAttribute('y', '-3');
    beadHi.setAttribute('width', '2'); beadHi.setAttribute('height', '2');
    beadHi.setAttribute('fill', '#d0d0d0');
    sym.appendChild(beadHi);
    // Shadow pixel (bottom-right)
    const beadSh = document.createElementNS(NS, 'rect');
    beadSh.setAttribute('x', '1'); beadSh.setAttribute('y', '1');
    beadSh.setAttribute('width', '2'); beadSh.setAttribute('height', '2');
    beadSh.setAttribute('fill', '#707070');
    sym.appendChild(beadSh);
    defs.appendChild(sym);

    // Pixel handle: 14x14 square with pixel shading
    const handleSym = document.createElementNS(NS, 'symbol');
    handleSym.id = 'handle-sym';
    handleSym.setAttribute('overflow', 'visible');
    // Invisible hit area
    const hitArea = document.createElementNS(NS, 'circle');
    hitArea.setAttribute('r', '18');
    hitArea.setAttribute('fill', 'transparent');
    handleSym.appendChild(hitArea);
    // Base square
    const hBase = document.createElementNS(NS, 'rect');
    hBase.setAttribute('x', '-7'); hBase.setAttribute('y', '-7');
    hBase.setAttribute('width', '14'); hBase.setAttribute('height', '14');
    hBase.setAttribute('fill', '#b0b0b0');
    handleSym.appendChild(hBase);
    // Top-left highlight (3x3)
    const hHi = document.createElementNS(NS, 'rect');
    hHi.setAttribute('x', '-7'); hHi.setAttribute('y', '-7');
    hHi.setAttribute('width', '4'); hHi.setAttribute('height', '4');
    hHi.setAttribute('fill', '#e0e0e0');
    handleSym.appendChild(hHi);
    // Top edge highlight
    const hTop = document.createElementNS(NS, 'rect');
    hTop.setAttribute('x', '-3'); hTop.setAttribute('y', '-7');
    hTop.setAttribute('width', '10'); hTop.setAttribute('height', '2');
    hTop.setAttribute('fill', '#d0d0d0');
    handleSym.appendChild(hTop);
    // Left edge highlight
    const hLeft = document.createElementNS(NS, 'rect');
    hLeft.setAttribute('x', '-7'); hLeft.setAttribute('y', '-3');
    hLeft.setAttribute('width', '2'); hLeft.setAttribute('height', '10');
    hLeft.setAttribute('fill', '#d0d0d0');
    handleSym.appendChild(hLeft);
    // Bottom-right shadow (3x3)
    const hSh = document.createElementNS(NS, 'rect');
    hSh.setAttribute('x', '3'); hSh.setAttribute('y', '3');
    hSh.setAttribute('width', '4'); hSh.setAttribute('height', '4');
    hSh.setAttribute('fill', '#707070');
    handleSym.appendChild(hSh);
    // Bottom edge shadow
    const hBot = document.createElementNS(NS, 'rect');
    hBot.setAttribute('x', '-7'); hBot.setAttribute('y', '5');
    hBot.setAttribute('width', '10'); hBot.setAttribute('height', '2');
    hBot.setAttribute('fill', '#808080');
    handleSym.appendChild(hBot);
    // Right edge shadow
    const hRight = document.createElementNS(NS, 'rect');
    hRight.setAttribute('x', '5'); hRight.setAttribute('y', '-7');
    hRight.setAttribute('width', '2'); hRight.setAttribute('height', '10');
    hRight.setAttribute('fill', '#808080');
    handleSym.appendChild(hRight);
    defs.appendChild(handleSym);

    svg.appendChild(defs);

    for (let i = 0; i < MAX_BEADS; i++) {
      const el = document.createElementNS(NS, 'use');
      el.setAttribute('href', '#bead-sym');
      svg.appendChild(el);
      linkEls.push(el);
    }

    // Handle element — rendered on top of beads
    handleEl = document.createElementNS(NS, 'use');
    handleEl.setAttribute('href', '#handle-sym');
    handleEl.style.pointerEvents = 'none';
    svg.appendChild(handleEl);
  })();

  // ── Init nodes — drop in from off-screen with random swing ───
  let loopStart = performance.now();
  const swingX = (Math.random() < 0.5 ? 1 : -1) * (15 + Math.random() * 25);
  function initNodes() {
    nodes.length = 0;
    loopStart = performance.now();
    for (let i = 0; i < NUM_NODES; i++) {
      const restY = i * LINK_LEN;
      const y = restY - 200;
      const t = i / (NUM_NODES - 1);
      const x = CX + swingX * t;
      nodes.push({ x, y, px: x, py: y - 14 });
    }
  }
  initNodes();

  // ── Physics tick ──────────────────────────────────────────────
  function tick() {
    // Verlet integration (skip anchor at i=0)
    for (let i = 1; i < NUM_NODES; i++) {
      const n = nodes[i];
      const vx = (n.x - n.px) * DAMPING;
      const vy = (n.y - n.py) * DAMPING;
      n.px = n.x; n.py = n.y;
      n.x += vx; n.y += vy + GRAVITY;
    }

    // Cursor influence — nudge nodes sideways when cursor brushes past
    const cvx = mouseX - prevMouseX, cvy = mouseY - prevMouseY;
    const speed = Math.sqrt(cvx * cvx + cvy * cvy);
    if (speed > 0.3) {
      for (let i = 1; i < NUM_NODES; i++) {
        const n = nodes[i];
        const dx = n.x - mouseX, dy = n.y - mouseY;
        const d2 = dx * dx + dy * dy;
        if (d2 < CURSOR_R * CURSOR_R) {
          const dist = Math.sqrt(d2);
          const falloff = 1 - dist / CURSOR_R;
          // Only apply tangential component — removes the repulsion on approach
          const nx = dx / dist, ny = dy / dist;
          const dot = cvx * nx + cvy * ny;
          const tx = cvx - dot * nx, ty = cvy - dot * ny;
          n.x += tx * falloff * CURSOR_F;
          n.y += ty * falloff * CURSOR_F;
        }
      }
    }

    // Handle sticky — when hovering, handle gently follows cursor
    if (!dragging && handleHovered) {
      const last = nodes[NUM_NODES - 1];
      const dx = mouseX - last.x, dy = mouseY - last.y;
      const STICKY_F = 0.06;
      last.x += dx * STICKY_F;
      last.y += dy * STICKY_F;
    }

    // Constraint solving
    for (let iter = 0; iter < ITERS; iter++) {
      nodes[0].x = CX; nodes[0].y = 0;
      for (let i = 0; i < NUM_NODES - 1; i++) {
        const a = nodes[i], b = nodes[i + 1];
        const dx = b.x - a.x, dy = b.y - a.y;
        const d = Math.sqrt(dx * dx + dy * dy) || 0.001;
        const c = (d - LINK_LEN) / d * 0.5;
        if (i > 0) { a.x += dx * c; a.y += dy * c; }
        b.x -= dx * c; b.y -= dy * c;
      }
      if (dragging) {
        nodes[NUM_NODES - 1].x = dragTargetX;
        nodes[NUM_NODES - 1].y = dragTargetY;
      }
    }

    if (dragging) {
      const pullDist = Math.sqrt((dragTargetX - CX) ** 2 + dragTargetY ** 2) - NATURAL_H;
      handleEl.style.opacity = (pullDist / TRIGGER) > 0.75 ? '0.5' : '1';
    }
  }

  // ── Interpolate a point at fraction t (0..1) along the rope ──
  function pointOnRope(t) {
    const segs = []; let total = 0;
    for (let i = 0; i < NUM_NODES - 1; i++) {
      const dx = nodes[i+1].x - nodes[i].x, dy = nodes[i+1].y - nodes[i].y;
      const l = Math.sqrt(dx*dx + dy*dy);
      segs.push(l); total += l;
    }
    const target = t * total;
    let acc = 0;
    for (let i = 0; i < NUM_NODES - 1; i++) {
      const next = acc + segs[i];
      if (next >= target || i === NUM_NODES - 2) {
        const lt = segs[i] > 0 ? Math.min(1, (target - acc) / segs[i]) : 0;
        return {
          x: nodes[i].x + (nodes[i+1].x - nodes[i].x) * lt,
          y: nodes[i].y + (nodes[i+1].y - nodes[i].y) * lt,
        };
      }
      acc = next;
    }
    return { x: nodes[NUM_NODES-1].x, y: nodes[NUM_NODES-1].y };
  }

  // ── Render ────────────────────────────────────────────────────
  function render() {
    const last = nodes[NUM_NODES - 1];
    svg.setAttribute('height', Math.max(last.y + 22, 20));

    // Measure rope and place beads at even intervals (more beads when pulled)
    let ropeLen = 0;
    for (let i = 0; i < NUM_NODES - 1; i++) {
      const dx = nodes[i+1].x - nodes[i].x, dy = nodes[i+1].y - nodes[i].y;
      ropeLen += Math.sqrt(dx*dx + dy*dy);
    }
    // Beads indexed from bottom — skip i=0 (handle occupies that position)
    const numBeads = Math.min(MAX_BEADS, Math.floor(ropeLen / LINK_LEN));

    for (let i = 0; i < MAX_BEADS; i++) {
      const el = linkEls[i];
      const bi = i + 1; // offset by 1 so beads start above the handle
      if (i < numBeads) {
        const t = Math.max(0, 1 - (bi * LINK_LEN) / ropeLen);
        const pt = pointOnRope(t);
        el.setAttribute('transform', `translate(${pt.x},${pt.y})`);
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    }

    handleEl.setAttribute('transform', `translate(${last.x},${last.y + 5})`);
    // Position the HTML hit-area overlay on top of the SVG handle
    const svgRect = svg.getBoundingClientRect();
    handleHit.style.left = `${last.x}px`;
    handleHit.style.top = `${last.y + 5}px`;
  }

  // ── Loop (stops when settled + cursor away) ───────────────────
  function settled() {
    return nodes.every((n, i) =>
      i === 0 || (Math.abs(n.x - n.px) < 0.05 && Math.abs(n.y - n.py) < 0.05));
  }
  function cursorNear() {
    return nodes.some(n => (n.x - mouseX) ** 2 + (n.y - mouseY) ** 2 < CURSOR_R ** 2);
  }
  function loop() {
    tick(); render();
    const dropping = performance.now() - loopStart < 2500;
    animId = (dropping || !settled() || dragging || cursorNear()) ? requestAnimationFrame(loop) : null;
  }
  function run() { if (!animId) animId = requestAnimationFrame(loop); }

  // ── Pointer events (on HTML overlay for reliable cursor) ─────
  handleHit.addEventListener('pointerdown', e => {
    e.preventDefault();
    dragging = true; pendingToggle = false;
    startClientX = e.clientX; startClientY = e.clientY;
    startDragX = nodes[NUM_NODES - 1].x;
    startDragY = nodes[NUM_NODES - 1].y;
    handleHit.setPointerCapture(e.pointerId);
    document.body.classList.add('chain-grabbing');
    window.__cursorRing?.hideAll();
    run();
  });

  handleHit.addEventListener('pointermove', e => {
    if (!dragging) return;
    let tx = startDragX + (e.clientX - startClientX);
    let ty = startDragY + (e.clientY - startClientY);
    // Cap total pull distance from anchor
    const tdx = tx - CX, tdy = ty;
    const dist = Math.sqrt(tdx * tdx + tdy * tdy);
    if (dist > MAX_PULL) {
      const s = MAX_PULL / dist;
      tx = CX + tdx * s; ty = tdy * s;
    }
    dragTargetX = tx; dragTargetY = ty;
    const pullDist = dist - NATURAL_H;
    if (pullDist >= TRIGGER) pendingToggle = true;
    run();
  });

  handleHit.addEventListener('pointerup', e => {
    if (!dragging) return;
    dragging = false;
    handleEl.style.opacity = '1';
    document.body.classList.remove('chain-grabbing');
    window.__cursorRing?.unhideAll();
    if (pendingToggle) {
      document.documentElement.classList.toggle('dark');
      localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    }
    pendingToggle = false;
    dragTargetX = CX; dragTargetY = NATURAL_H;
    run();
  });

  // ── Cursor ring for chain handle ─────────────────────────────
  handleHit.addEventListener('mouseenter', () => {
    handleHovered = true;
    window.__cursorRing?.show();
    window.__cursorRing?.showLabel();
  });
  handleHit.addEventListener('mouseleave', () => {
    handleHovered = false;
    window.__cursorRing?.hide();
    window.__cursorRing?.hideLabel();
  });

  // ── Cursor tracking ───────────────────────────────────────────
  document.addEventListener('mousemove', e => {
    prevMouseX = mouseX; prevMouseY = mouseY;
    const r = svg.getBoundingClientRect();
    mouseX = e.clientX - r.left;
    mouseY = e.clientY - r.top;
    run();
  });

  // ── Init (chain stays hidden until hero intro finishes) ──────
  // Don't render or run yet — wait for revealChain()


  // ── Match block width to name heading ───────────────────────────
  const heroName = document.getElementById('hero-name');
  const heroBlock = document.getElementById('hero-block');
  function matchBlockWidth() {
    if (heroName && heroBlock) {
      // Reset to auto first so w-max can take effect
      heroBlock.style.width = '';
      requestAnimationFrame(() => {
        heroBlock.style.width = heroName.offsetWidth + 'px';
      });
    }
  }
  document.fonts.ready.then(() => {
    // Double rAF to ensure layout is settled after font swap
    requestAnimationFrame(() => requestAnimationFrame(() => {
      matchBlockWidth();
      // Start intro animations only after width is locked
      requestAnimationFrame(() => {
        heroBlock?.classList.add('intro-ready');
        // Clean up face intro after animation so hover transition takes over
        const faceImg = document.querySelector('.intro-face');
        if (faceImg) {
          faceImg.addEventListener('animationend', () => {
            faceImg.classList.remove('intro-face');
            faceImg.style.transform = '';
          });
        }
        // Reveal chain after hero intro completes
        setTimeout(() => {
          const chainRoot = document.getElementById('chain-root');
          if (chainRoot) chainRoot.style.visibility = '';
          initNodes();
          render();
          run();
        }, 600);
      });
    }));
  });
  window.addEventListener('resize', matchBlockWidth);
</script>

<style>
  .shelf-line {
    background: linear-gradient(to right, transparent, #9a9088 20%, #9a9088 80%, transparent);
  }
  :global(.dark) .shelf-line {
    background: linear-gradient(to right, transparent, #3a4d5e 20%, #3a4d5e 80%, transparent);
  }

  .hero-matt {
    font-size: clamp(8rem, 21vw, 18rem);
    line-height: 0.85;
    position: relative;
    letter-spacing: 0.02em;
    padding-bottom: 0.15em;
    margin-bottom: -0.15em;
  }
  .hero-matt::after { display: none; }
  .hero-stenback {
    font-family: 'ObviouslyCondensed', 'Obviously', sans-serif;
    font-size: clamp(6rem, 15.8vw, 13.5rem);
    line-height: 0.85;
    margin-top: 0.016em;
    padding-bottom: 0.15em;
    margin-bottom: -0.15em;
    position: relative;
    z-index: 1;
    letter-spacing: 0.02em;
  }

  /* Per-letter kerning — MATT */
  .kern-M { margin-right: 0.03em; }
  .kern-A1 { margin-right: -0.01em; }
  .kern-T1 { margin-right: 0.02em; }

  /* Per-letter kerning — STENBACK */
  .kern-S { margin-right: 0.02em; }
  .kern-T3 { margin-right: 0.02em; }
  .kern-E { margin-right: 0.01em; }
  .kern-A2 { margin-right: -0.01em; }
  .kern-C { margin-right: 0.02em; }

  /* Face container — between the two T's of MATT, bottom aligned to gap */
  .face-container {
    position: absolute;
    left: 60%;
    /* Bottom of face sits below gap center between the two names */
    top: auto;
    bottom: 35%;
    transform: translateX(-50%);
    z-index: 10;
  }
  .face-container .face-wrap {
    width: clamp(80px, 11.4vw, 182px);
    height: clamp(96px, 13.7vw, 219px);
    overflow: hidden;
  }
  .face-container::before {
    content: '';
    position: absolute;
