<!-- Star pull-chain — bouncing invincibility star, rainbow seizure mode -->
<div id="star-chain-root" class="fixed z-50 flex flex-col items-center"
  style="top: -10px; left: calc(50% + min(120px, 17.5vw) * 2); width: 20px; transform: translateX(-50%); user-select: none; -webkit-user-select: none; visibility: hidden;">
  <svg id="star-chain-svg" width="20" xmlns="http://www.w3.org/2000/svg"
    style="overflow: visible; display: block; flex-shrink: 0;"
    shape-rendering="crispEdges">
  </svg>
  <div id="star-handle-hit" style="position:absolute; width:44px; height:44px; border-radius:50%; pointer-events:auto; cursor: url('/images/cursor-grab.svg') 14 14, grab; transform: translate(-50%, -50%); touch-action: none;"></div>
</div>

<div id="star-layer" style="position:fixed; inset:0; pointer-events:none; z-index:40; overflow:hidden;"></div>

<script>
  import { createChain } from '../scripts/chain-physics.js';

  const starChain = createChain({
    svgId: 'star-chain-svg',
    handleHitId: 'star-handle-hit',
    rootId: 'star-chain-root',
    cursorLabel: 'Cover your eyes',
    trigger: 30,
    handleSymbolId: 'star-handle-sym',
    buildHandleSymbol(NS) {
      const sym = document.createElementNS(NS, 'symbol');
      const hit = document.createElementNS(NS, 'circle');
      hit.setAttribute('r', '18'); hit.setAttribute('fill', 'transparent');
      sym.appendChild(hit);
      // Base gold
      const base = document.createElementNS(NS, 'rect');
      base.setAttribute('x', '-7'); base.setAttribute('y', '-7');
      base.setAttribute('width', '14'); base.setAttribute('height', '14');
      base.setAttribute('fill', '#d4a820');
      sym.appendChild(base);
      // Highlight top-left
      const hi = document.createElementNS(NS, 'rect');
      hi.setAttribute('x', '-7'); hi.setAttribute('y', '-7');
      hi.setAttribute('width', '4'); hi.setAttribute('height', '4');
      hi.setAttribute('fill', '#ffe040');
      sym.appendChild(hi);
      // Highlight top edge
      const ht = document.createElementNS(NS, 'rect');
      ht.setAttribute('x', '-3'); ht.setAttribute('y', '-7');
      ht.setAttribute('width', '10'); ht.setAttribute('height', '2');
      ht.setAttribute('fill', '#e8c030');
      sym.appendChild(ht);
      // Highlight left edge
      const hl = document.createElementNS(NS, 'rect');
      hl.setAttribute('x', '-7'); hl.setAttribute('y', '-3');
      hl.setAttribute('width', '2'); hl.setAttribute('height', '10');
      hl.setAttribute('fill', '#e8c030');
      sym.appendChild(hl);
      // Shadow bottom-right
      const sh = document.createElementNS(NS, 'rect');
      sh.setAttribute('x', '3'); sh.setAttribute('y', '3');
      sh.setAttribute('width', '4'); sh.setAttribute('height', '4');
      sh.setAttribute('fill', '#906010');
      sym.appendChild(sh);
      // Shadow bottom edge
      const sb = document.createElementNS(NS, 'rect');
      sb.setAttribute('x', '-7'); sb.setAttribute('y', '5');
      sb.setAttribute('width', '10'); sb.setAttribute('height', '2');
      sb.setAttribute('fill', '#a07818');
      sym.appendChild(sb);
      // Shadow right edge
      const sr = document.createElementNS(NS, 'rect');
      sr.setAttribute('x', '5'); sr.setAttribute('y', '-7');
      sr.setAttribute('width', '2'); sr.setAttribute('height', '10');
      sr.setAttribute('fill', '#a07818');
      sym.appendChild(sr);
      // Center sparkle
      const dot = document.createElementNS(NS, 'rect');
      dot.setAttribute('x', '-2'); dot.setAttribute('y', '-2');
      dot.setAttribute('width', '4'); dot.setAttribute('height', '4');
      dot.setAttribute('fill', '#ffffff');
      sym.appendChild(dot);
      return sym;
    },
    onTrigger: () => spawnStarRain(),
  });

  // Reveal on phase-2 dialog trigger
  document.addEventListener('chain-reveal', e => {
    if (e.detail.phase === 'phase-2') starChain.reveal();
  });
  document.addEventListener('chain-reset', () => {
    starChain.hide();
    clearAllStars();
    cancelStarMode();
  });

  // ── Star Sprite ────────────────────────────────────────────────
  const SW = 60, SH = 60;

  // ── Multi-Star System ─────────────────────────────────────────
  const starLayer = document.getElementById('star-layer')!;
  const stars: {
    el: HTMLDivElement; x: number; y: number; vx: number; vy: number;
    burstTimer: number; bursting: boolean;
  }[] = [];
  let starAnimId: number | null = null;
  let starModeEndTimer: number | null = null;

  function spawnStar() {
    const vw = window.innerWidth;
    const x = Math.random() * (vw - SW);
    const y = -SH;
    const speed = 8 + Math.random() * 3;
    const vx = (Math.random() < 0.5 ? -1 : 1) * speed;
    const vy = speed;

    const el = document.createElement('div');
    el.style.cssText = `position:absolute;width:${SW}px;height:${SH}px;background-image:url(/images/star.png);background-size:contain;background-repeat:no-repeat;image-rendering:pixelated;will-change:transform;pointer-events:none;animation:rainbow-spin 0.3s linear infinite;`;
    el.style.transform = `translate(${Math.round(x)}px,${Math.round(y)}px)`;
    starLayer.appendChild(el);

    // Each star gets its own 3s burst timer
    const burstTimer = window.setTimeout(() => burstStar(star), 3000);
    const star = { el, x, y, vx, vy, burstTimer, bursting: false };
    stars.push(star);
    startStarLoop();
    return star;
  }

  function spawnStarRain() {
    spawnStar();
  }

  function removeStar(s) {
    s.el.remove();
    const idx = stars.indexOf(s);
    if (idx !== -1) stars.splice(idx, 1);
  }

  function clearAllStars() {
    for (const s of stars) {
      clearTimeout(s.burstTimer);
      s.el.remove();
    }
    stars.length = 0;
    if (starAnimId) {
      cancelAnimationFrame(starAnimId);
      starAnimId = null;
    }
  }

  // ── Bounce Physics (DVD-screensaver style) ────────────────────
  function burstAt(x: number, y: number) {
    for (let i = 0; i < 6; i++) {
      const spark = document.createElement('div');
      const angle = (Math.PI * 2 / 6) * i + Math.random() * 0.5;
      const dist = 20 + Math.random() * 30;
      const dx = Math.cos(angle) * dist;
      const dy = Math.sin(angle) * dist;
      spark.style.cssText = `position:absolute;width:6px;height:6px;background:#ffe040;border-radius:50%;left:${x}px;top:${y}px;pointer-events:none;will-change:transform,opacity;transition:transform 0.35s ease-out, opacity 0.35s ease-out;box-shadow:0 0 8px #ffe040;`;
      starLayer.appendChild(spark);
      requestAnimationFrame(() => {
        spark.style.transform = `translate(${dx}px,${dy}px)`;
        spark.style.opacity = '0';
      });
      setTimeout(() => spark.remove(), 350);
    }
  }

  function starTick() {
    const maxX = window.innerWidth - SW;
    const maxY = window.innerHeight - SH;

    for (const s of stars) {
      if (s.bursting) continue; // frozen mid-burst

      s.x += s.vx;
      s.y += s.vy;

      let bounced = false;
      let bx = s.x + SW / 2, by = s.y + SH / 2;

      if (s.x < 0) { s.x = 0; s.vx = -s.vx; bounced = true; bx = 0; }
      else if (s.x > maxX) { s.x = maxX; s.vx = -s.vx; bounced = true; bx = maxX + SW; }

      if (s.y < 0) { s.y = 0; s.vy = -s.vy; bounced = true; by = 0; }
      else if (s.y > maxY) { s.y = maxY; s.vy = -s.vy; bounced = true; by = maxY + SH; }

      if (bounced) burstAt(bx, by);

      s.el.style.transform = `translate(${Math.round(s.x)}px,${Math.round(s.y)}px)`;
    }

    if (stars.length > 0) {
      starAnimId = requestAnimationFrame(starTick);
    } else {
      starAnimId = null;
    }
  }

  function startStarLoop() {
    if (!starAnimId) starAnimId = requestAnimationFrame(starTick);
  }

  // ── Star Burst (per-star) ─────────────────────────────────────
  const BURST_COLORS = ['#ffe040', '#ffb020', '#ff6020', '#ffffff', '#d4a820', '#ff4060'];

  function burstStar(s) {
    if (s.bursting) return;
    s.bursting = true; // stop movement

    const sx = s.x + SW / 2, sy = s.y + SH / 2;

    // White flash overlay
    const flash = document.createElement('div');
    flash.style.cssText = `position:fixed;inset:0;background:white;pointer-events:none;z-index:100;opacity:0.8;transition:opacity 0.5s ease-out;`;
    document.body.appendChild(flash);
    requestAnimationFrame(() => { flash.style.opacity = '0'; });
    setTimeout(() => flash.remove(), 500);

    // 20 particles radiating outward
    for (let i = 0; i < 20; i++) {
      const p = document.createElement('div');
      const size = 4 + Math.floor(Math.random() * 8);
      const color = BURST_COLORS[Math.floor(Math.random() * BURST_COLORS.length)];
      const angle = (Math.PI * 2 / 20) * i + (Math.random() - 0.5) * 0.3;
      const dist = 80 + Math.random() * 150;
      const dx = Math.cos(angle) * dist;
      const dy = Math.sin(angle) * dist;
      p.style.cssText = `position:absolute;width:${size}px;height:${size}px;background:${color};left:${sx}px;top:${sy}px;pointer-events:none;will-change:transform,opacity;transition:transform 0.6s cubic-bezier(0.22,1,0.36,1), opacity 0.6s ease-out;box-shadow:0 0 ${size}px ${color};`;
      starLayer.appendChild(p);
      requestAnimationFrame(() => {
        p.style.transform = `translate(${dx}px,${dy}px) scale(0.2)`;
        p.style.opacity = '0';
      });
      setTimeout(() => p.remove(), 600);
    }

    // Star freezes, scales up, and slowly fades out
    s.el.style.animation = 'none';
    s.el.style.transition = 'transform 0.6s cubic-bezier(0.22,1,0.36,1), opacity 0.8s ease-out, filter 0.3s ease-out';
    s.el.style.filter = 'brightness(3)';
    s.el.style.transform += ' scale(2.5)';
    s.el.style.opacity = '0';
    setTimeout(() => removeStar(s), 800);

    // Activate star mode (stacks — each burst resets the end timer)
    activateStarMode();
  }

  // ── Star Mode ───────────────────────────────────────────────────
  function activateStarMode() {
    document.documentElement.classList.add('star-mode');
    // Reset end timer — star mode persists 3.5s after LAST burst
    if (starModeEndTimer) clearTimeout(starModeEndTimer);
    starModeEndTimer = window.setTimeout(() => {
      document.documentElement.classList.remove('star-mode');
      starModeEndTimer = null;
    }, 3500);
  }

  function cancelStarMode() {
    if (starModeEndTimer) { clearTimeout(starModeEndTimer); starModeEndTimer = null; }
    document.documentElement.classList.remove('star-mode');
  }


  // Expose for portal reset
  (window as any).__starEffect = {
    clear() {
      clearAllStars();
      cancelStarMode();
    },
  };
</script>

<style>
  :global(.star-mode) {
    animation: rainbow-hue 0.3s linear infinite !important;
    overflow: hidden;
  }
  :global(.star-mode) :global(body) {
    animation: screen-shake 0.05s linear infinite;
  }
  @keyframes rainbow-hue {
    from { filter: hue-rotate(0deg) saturate(1.5) brightness(1.1); }
    to { filter: hue-rotate(360deg) saturate(1.5) brightness(1.1); }
  }
  @keyframes screen-shake {
    0% { transform: translate(0, 0); }
    25% { transform: translate(-2px, 1px); }
    50% { transform: translate(2px, -1px); }
    75% { transform: translate(-1px, -2px); }
    100% { transform: translate(1px, 2px); }
  }
  @keyframes rainbow-spin {
    from { filter: hue-rotate(0deg) brightness(1.2); }
    to { filter: hue-rotate(360deg) brightness(1.2); }
  }
</style>
